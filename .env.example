# --- Backend (Express) ---
PORT=3001
JWT_SECRET=change-this-to-a-strong-random-secret

# --- Solana ---
# SOLANA_NETWORK=devnet
# SOLANA_KEYPAIR_PATH=./solana/keypair.json
