# ============================================
# ChainFund — Environment Variables
# ============================================
# Set these in Netlify dashboard:
# Site Settings → Build & Deploy → Environment Variables

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Auth ---
JWT_SECRET=change-this-to-a-strong-random-secret

# --- Solana ---
SOLANA_NETWORK=devnet
SOLANA_KEYPAIR=[1,2,3,...]  # JSON array of wallet secret key bytes

# --- Frontend (Vite) — usually not needed with Netlify Functions ---
# VITE_API_URL=/api  # default, uses redirects in netlify.toml

# --- Local development (Express backend) ---
# PORT=3001
